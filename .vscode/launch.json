{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Backend: Debug Server",
      "args": ["backend/server.ts"],
      "runtimeExecutable": "tsx",
      "env": { "NODE_ENV": "development" },
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Frontend: Debug Chrome",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ]
}
